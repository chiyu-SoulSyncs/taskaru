# ─── Database ─────────────────────────────────────────────
# MySQL接続URL
DATABASE_URL=mysql://user:password@localhost:3306/taskaru

# ─── Session / JWT ────────────────────────────────────────
# 本番環境では64文字以上のランダム文字列を使用してください
# 生成コマンド: openssl rand -base64 48
JWT_SECRET=change-me-to-a-random-64-char-string-XXXXXXXXXXXXXXXX

# ─── Google OAuth 2.0 ────────────────────────────────────
# Google Cloud Console → APIs & Services → Credentials で取得
# https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# アプリのベースURL（OAuth コールバックで使用）
APP_URL=http://localhost:3000

# ─── LLM API (OpenAI互換) ────────────────────────────────
# Google Gemini: https://generativelanguage.googleapis.com/v1beta/openai
# OpenAI:       https://api.openai.com/v1
# OpenRouter:   https://openrouter.ai/api/v1
LLM_API_URL=https://generativelanguage.googleapis.com/v1beta/openai
LLM_API_KEY=
LLM_MODEL=gemini-2.5-flash

# ─── LINE Messaging API ──────────────────────────────────
# LINE Developers Console → チャネル設定 で取得
# https://developers.line.biz/console/
LINE_CHANNEL_SECRET=
LINE_CHANNEL_ACCESS_TOKEN=

# ─── Server ───────────────────────────────────────────────
PORT=3000
NODE_ENV=development
